# Environment variables example file
# Copy this to `.env` and fill in values for your environment.
#
# IMPORTANT:
# - Do not commit real secrets (JWT keys, AWS keys, Firebase credentials, DB passwords).
# - Use strong secrets in production.
#
# Server
PORT=3000
NODE_ENV=development
API_PREFIX=/api/v1
APP_URL=http://localhost:3000
BASE_URL=http://localhost:3000
CORS_ORIGIN=*

# Database (PostgreSQL)
# Example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/promo_play?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/promo_play"

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Optional token expiry settings
PASSWORD_RESET_TOKEN_EXPIRY=3600

# Email / SMTP (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME="Promo Play"
FRONTEND_URL=http://localhost:3000

# Admin (optional)
ADMIN_EMAIL=admin@example.com

# Order (optional)
PLATFORM_FEE_PERCENTAGE=10
DEFAULT_SHIPPING_COST=5.00
TAX_PERCENTAGE=0

# AWS (S3 + CloudFront) (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_ACL=private
AWS_S3_SSE=AES256
AWS_KMS_KEY_ID=
AWS_USE_IAM_ROLE=false
CDN_URL=
AWS_S3_ENABLE_CDN=false
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY=
AWS_CLOUDFRONT_SIGNED_URL_EXPIRY=3600

# Firebase (optional)
# Provide either a file path OR a base64 service account JSON.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PROJECT_ID=


